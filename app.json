{
  "expo": {
    "name": "empowerme-biz",
    "slug": "empowerme-biz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/empower-biz.png",
    "scheme": "empowermebiz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/empower-biz.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/empower-biz.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/empower-biz.png",
          "resizeMode": "cover",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/empower-biz.png",
            "resizeMode": "cover",
            "backgroundColor": "#121517"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "642785d6-1212-4a75-9c13-b46c468a9569"
      }
    },
    "owner": "augustineezinwa"
  }
}
